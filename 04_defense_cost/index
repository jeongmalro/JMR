  { label: '2019년 타결 명목 상승', num: '+8.2', unit: '%', sub: '교착 후 1년 협정\n9,602→10,389억', c: '#f8a04a' },
  { label: '바이든기 2021년 명목', num: '+13.9', unit: '%', sub: '트럼프1기 교착 해소\n역대 최대 단년 인상', c: '#44ddaa' },
];
const statCards = document.getElementById('statCards');
statDefs.forEach(s => {
  const div = document.createElement('div');
  div.className = 'stat-card';
  div.style.setProperty('--c', s.c);
  div.innerHTML = `<div><span class="stat-num">${s.num}</span><span class="stat-unit">${s.unit}</span></div>
    <div class="stat-label">${s.label}</div>
    <div class="stat-sub">${s.sub.replace('\n','<br>')}</div>`;
  statCards.appendChild(div);
});

// ── PRESIDENT BANDS ──────────────────────────────────────────
const bandsEl = document.getElementById('presBands');
usPres.forEach(p => {
  const count = p.end - p.start + 1;
  const div = document.createElement('div');
  div.className = 'pres-band';
  div.style.background = p.color;
  div.style.gridColumn = `span ${count}`;
  div.style.flex = count;
  div.textContent = p.name;
  bandsEl.appendChild(div);
});

// ── COMMON CHART OPTIONS ─────────────────────────────────────
const gridColor = '#1e1e2c';
const tooltipStyle = {
  backgroundColor: '#1a1a2e', titleColor: '#f0c040',
  bodyColor: '#e4e4f0', borderColor: '#2e2e3e', borderWidth: 1
};

// ── BACKGROUND REGION PLUGIN ─────────────────────────────────
function makeBgPlugin(presArr) {
  return {
    id: 'bgRegions',
    beforeDraw(chart) {
      const { ctx, chartArea, scales } = chart;
      if (!chartArea) return;
      presArr.forEach(p => {
        const si = getYearIdx(p.start);
        const ei = getYearIdx(p.end);
        if (si < 0 || ei < 0) return;
        const x1 = scales.x.getPixelForValue(si);
        const x2 = scales.x.getPixelForValue(ei);
        ctx.save();
        ctx.fillStyle = p.color + (p.isTrump ? '22' : '0d');
        ctx.fillRect(x1, chartArea.top, x2 - x1 + scales.x.width / years.length, chartArea.height);
        if (p.isTrump) {
          ctx.strokeStyle = p.color + '55';
          ctx.lineWidth = 1;
          ctx.setLineDash([3, 3]);
          ctx.strokeRect(x1, chartArea.top, x2 - x1 + scales.x.width / years.length, chartArea.height);
          ctx.setLineDash([]);
        }
        ctx.fillStyle = p.color + 'bb';
        ctx.font = `${p.isTrump ? '700' : '600'} 9px IBM Plex Mono`;
        ctx.fillText(p.name, x1 + 4, chartArea.top + 13);
        ctx.restore();
      });
    }
  };
}

const xTicks = {
  color: '#5a5a78', font: { family: 'IBM Plex Mono', size: 10 },
  callback: (_, i) => years[i] % 4 === 0 ? `'${String(years[i]).slice(2)}` : ''
};
const yTicksPct = {
  color: '#5a5a78', font: { family: 'IBM Plex Mono', size: 10 },
  callback: v => `${v > 0 ? '+' : ''}${v}%`
};

// ── CHART 1: 명목 분담금 ────────────────────────────────────
new Chart(document.getElementById('nominalChart').getContext('2d'), {
  type: 'bar',
  plugins: [makeBgPlugin(usPres)],
  data: {
    labels: years.map((_, i) => i),
    datasets: [{
      label: '명목 분담금 (억원)',
      data: nominal,
      backgroundColor: years.map((y, i) => {
        const isTrump = (y >= 2017 && y <= 2020) || y === 2025;
        return isTrump ? 'rgba(255,68,85,.75)' : 'rgba(240,192,64,.55)';
      }),
      borderColor: years.map((y) => {
        const isTrump = (y >= 2017 && y <= 2020) || y === 2025;
        return isTrump ? '#ff4455' : '#f0c040';
      }),
      borderWidth: 1, borderRadius: 2,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { ...tooltipStyle,
        callbacks: {
          title: ctx => `${years[ctx[0].dataIndex]}년`,
          label: ctx => ` ${ctx.raw.toLocaleString()}억원`
        }
      }
    },
    scales: {
      x: { grid: { color: gridColor }, ticks: xTicks },
      y: { grid: { color: gridColor },
        ticks: { color: '#5a5a78', font: { family: 'IBM Plex Mono', size: 10 },
          callback: v => `${(v/10000).toFixed(0)}조` } }
    }
  }
});

// 범례
const legendEl = document.getElementById('nominalLegend');
legendEl.innerHTML = `
  <div class="legend-item"><div class="legend-dot" style="background:#f0c040"></div>일반 구간</div>
  <div class="legend-item"><div class="legend-dot" style="background:#ff4455"></div>트럼프 구간 (2017-2020, 2025)</div>
`;

// ── CHART 2: 명목 vs 실질 상승률 ────────────────────────────
const validYears = years.slice(1);
const validNomRate = nominalRate.slice(1);
const validRealRate = realRate.slice(1);

new Chart(document.getElementById('rateChart').getContext('2d'), {
  type: 'bar',
  plugins: [makeBgPlugin(usPres)],
  data: {
    labels: validYears.map((_, i) => i + 1),
    datasets: [
      {
        label: '명목 상승률',
        data: validNomRate,
        backgroundColor: validYears.map(y => {
          const isTrump = (y >= 2017 && y <= 2020) || y === 2025;
          return isTrump ? 'rgba(255,68,85,.8)' : 'rgba(240,192,64,.65)';
        }),
        borderColor: validYears.map(y => {
          const isTrump = (y >= 2017 && y <= 2020) || y === 2025;
          return isTrump ? '#ff4455' : '#f0c040';
        }),
        borderWidth: 1, borderRadius: 2, order: 2,
      },
      {
        label: '실질 상승률 (물가 반영)',
        data: validRealRate,
        type: 'line',
        borderColor: '#4a9eff',
        backgroundColor: 'rgba(74,158,255,.1)',
        borderWidth: 2.5,
        pointRadius: 4,
        pointBackgroundColor: validYears.map(y => {
          const isTrump = (y >= 2017 && y <= 2020) || y === 2025;
          return isTrump ? '#ff4455' : '#4a9eff';
        }),
        pointBorderColor: 'transparent',
        fill: false, tension: 0.3, order: 1,
      }
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { ...tooltipStyle,
        callbacks: {
          title: ctx => `${validYears[ctx[0].dataIndex]}년`,
          label: ctx => ` ${ctx.dataset.label}: ${ctx.raw > 0 ? '+' : ''}${ctx.raw?.toFixed(2)}%`
        }
      }
    },
    scales: {
      x: { grid: { color: gridColor },
        ticks: {
          color: '#5a5a78', font: { family: 'IBM Plex Mono', size: 10 },
          callback: (_, i) => validYears[i] % 4 === 0 ? `'${String(validYears[i]).slice(2)}` : ''
        }
      },
      y: { grid: { color: gridColor }, ticks: yTicksPct }
    }
  }
});

// ── CHART 3: 대통령별 실질 평균 상승률 ──────────────────────
const presAvg = [
  { name: '클린턴\n(미)', years: [2000], color: '#7bed9f' },
  { name: '부시\n(미)', years: [2001,2002,2003,2004,2005,2006,2007,2008], color: '#f8a04a' },
  { name: '오바마\n(미)', years: [2009,2010,2011,2012,2013,2014,2015,2016], color: '#4a9eff' },
  { name: '트럼프1\n(미)', years: [2017,2018,2019,2020], color: '#ff4455', isTrump: true },
  { name: '바이든\n(미)', years: [2021,2022,2023,2024], color: '#44ddaa' },
  { name: '트럼프2\n(미)', years: [2025], color: '#ff6b35', isTrump: true },
];

const presAvgData = presAvg.map(p => {
  const rates = p.years.map(y => {
    const i = years.indexOf(y);
    return realRate[i];
  }).filter(r => r !== null && !isNaN(r));
  const avg = rates.reduce((a, b) => a + b, 0) / rates.length;
  return { ...p, avg: +avg.toFixed(2) };
});

new Chart(document.getElementById('presChart').getContext('2d'), {
  type: 'bar',
  data: {
    labels: presAvgData.map(p => p.name),
    datasets: [{
      data: presAvgData.map(p => p.avg),
      backgroundColor: presAvgData.map(p => p.color + (p.isTrump ? 'cc' : '88')),
      borderColor: presAvgData.map(p => p.color),
      borderWidth: p => p.isTrump ? 2 : 1,
      borderRadius: 3,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: { ...tooltipStyle,
        callbacks: {
          label: ctx => ` 실질 평균 상승률: ${ctx.raw > 0 ? '+' : ''}${ctx.raw}%`
        }
      }
    },
    scales: {
      x: { grid: { display: false },
        ticks: { color: '#8888aa', font: { family: 'IBM Plex Mono', size: 10 },
          maxRotation: 0 }
      },
      y: { grid: { color: gridColor }, ticks: yTicksPct }
    }
  }
});

// ── DATA TABLE ───────────────────────────────────────────────
const tbody = document.getElementById('tableBody');
years.forEach((y, i) => {
  const isTrump1 = y >= 2017 && y <= 2020;
  const isTrump2 = y === 2025;
  const tr = document.createElement('tr');
  if (isTrump1) tr.className = 'trump1';
  if (isTrump2) tr.className = 'trump2';

  const badge = isTrump1
    ? `<span class="pres-badge" style="background:rgba(255,68,85,.2);color:#ff4455;border:1px solid rgba(255,68,85,.4)">TRUMP1</span>`
    : isTrump2
      ? `<span class="pres-badge" style="background:rgba(255,107,53,.2);color:#ff6b35;border:1px solid rgba(255,107,53,.4)">TRUMP2</span>`
      : '';

  const nr = nominalRate[i] !== null ? `${nominalRate[i] > 0 ? '+' : ''}${nominalRate[i]?.toFixed(2)}%` : '—';
  const rr = realRate[i] !== null ? `${realRate[i] > 0 ? '+' : ''}${realRate[i]?.toFixed(2)}%` : '—';
  const rrColor = realRate[i] > 0 ? '#44ddaa' : realRate[i] < 0 ? '#ff4455' : '#8888aa';

  tr.innerHTML = `
    <td>${y}년 ${badge}</td>
    <td>${nominal[i].toLocaleString()}</td>
    <td style="color:${nominalRate[i]>0?'#f0c040':'#ff4455'}">${nr}</td>
    <td>${cpi[i].toFixed(1)}</td>
    <td>${realNominal[i].toFixed(2)}</td>
    <td style="color:${rrColor}">${rr}</td>
  `;
  tbody.appendChild(tr);
});
</script>
